{
  "expo": {
    "name": "炒菜助手",
    "slug": "CookHelper",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4511e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cookhelper.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4511e"
      },
      "package": "com.cookhelper.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/recipes.txt"
    ]
  }
}
